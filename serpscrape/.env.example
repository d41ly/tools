# ── Database ──────────────────────────────────────────────────────────────
# Serpscrape needs PostgreSQL. Pick ONE of the two options below.

# Option A — bundled PostgreSQL 16 container (run with the "bundled-db" profile):
#   docker compose --profile bundled-db up -d --build
POSTGRES_USER=serp
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_DB=serp
DATABASE_URL=postgresql+asyncpg://serp:changeme_postgres@db:5432/serp

# Option B — PostgreSQL 18 cluster running on the HOST machine (no profile):
#   docker compose up -d --build
# Point at host.docker.internal and the cluster's port (PG18 is often 5433 when a
# PG16 cluster also exists — check `pg_lsclusters`). The role/database must already
# exist on the host cluster. See the README "Database options" section for the
# required postgresql.conf / pg_hba.conf settings.
# DATABASE_URL=postgresql+asyncpg://serp:changeme_postgres@host.docker.internal:5432/serp

# ── App ───────────────────────────────────────────────────────────────────
# Master encryption key for secrets at rest (Fernet, 32 url-safe base64 bytes)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_SECRET_KEY=replace_me_with_a_fernet_key

# Hostname the UI is served behind (used to gate the /api/ui-token bootstrap endpoint)
UI_HOSTNAME=localhost

# Public base URL (used in email links)
PUBLIC_BASE_URL=http://localhost:8000

# Set to 0 to force headless Chromium (e.g. local dev without Xvfb). Default: headful.
# SCRAPER_HEADFUL=1
