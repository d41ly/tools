# Postgres
POSTGRES_USER=serp
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_DB=serp

# Database URL used by the app (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://serp:changeme_postgres@db:5432/serp

# Master encryption key for secrets at rest (Fernet, 32 url-safe base64 bytes)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_SECRET_KEY=replace_me_with_a_fernet_key

# Hostname the UI is served behind (used to gate the /api/ui-token bootstrap endpoint)
UI_HOSTNAME=localhost

# Public base URL (used in email links)
PUBLIC_BASE_URL=http://localhost:8000
